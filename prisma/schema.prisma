generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String?
  access_token      String?
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String?
  session_state     String?
  user              User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@map("accounts")
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("sessions")
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
  @@map("verification_tokens")
}

model Organization {
  id                String             @id @default(cuid())
  name              String
  slug              String             @unique
  domain            String?
  plan              String             @default("starter")
  createdAt         DateTime           @default(now()) @map("created_at")
  updatedAt         DateTime           @updatedAt @map("updated_at")
  reportPreferences Json?              @default("{}") @map("report_preferences")
  reportSchedule    String?            @default("weekly_monday") @map("report_schedule")
  deliveryConfig    Json?              @map("delivery_config")
  clientOnboardings ClientOnboarding[]
  events            Event[]
  integrations      Integration[]
  reportContexts    ReportContext[]
  reportRecipients  ReportRecipient[]
  reports           Report[]
  signals           Signal[]
  sprints           Sprint[]
  teams             Team[]
  users             User[]

  @@map("organizations")
}

model ClientOnboarding {
  id           String       @id @default(cuid())
  orgId        String       @map("org_id")
  token        String       @unique
  email        String
  clientName   String       @map("client_name")
  status       String       @default("PENDING")
  expiresAt    DateTime     @map("expires_at")
  completedAt  DateTime?    @map("completed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@map("client_onboardings")
}

model User {
  id                  String               @id @default(cuid())
  name                String?
  email               String?              @unique
  emailVerified       DateTime?            @map("email_verified")
  image               String?
  password            String?
  role                Role                 @default(MEMBER)
  orgId               String?              @map("org_id")
  createdAt           DateTime             @default(now()) @map("created_at")
  updatedAt           DateTime             @updatedAt @map("updated_at")
  accounts            Account[]
  deliveryPreferences DeliveryPreference[]
  events              Event[]
  reportDeliveries    ReportDelivery[]
  reviewedReports     Report[]             @relation("ReviewedReports")
  sessions            Session[]
  organization        Organization?        @relation(fields: [orgId], references: [id], onDelete: Cascade)
  teams               Team[]               @relation("TeamMembers")

  @@map("users")
}

model Team {
  id           String       @id @default(cuid())
  name         String
  slug         String       @unique
  description  String?
  orgId        String       @map("org_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  reports      Report[]
  sprints      Sprint[]
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  members      User[]       @relation("TeamMembers")

  @@map("teams")
}

model Integration {
  id           String            @id @default(cuid())
  type         IntegrationType
  status       IntegrationStatus @default(DISCONNECTED)
  config       Json              @default("{}")
  accessToken  String?           @map("access_token")
  refreshToken String?           @map("refresh_token")
  expiresAt    DateTime?         @map("expires_at")
  orgId        String            @map("org_id")
  createdAt    DateTime          @default(now()) @map("created_at")
  updatedAt    DateTime          @updatedAt @map("updated_at")
  organization Organization      @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, type])
  @@map("integrations")
}

model Event {
  id           String          @id @default(cuid())
  externalId   String          @map("external_id")
  source       IntegrationType
  type         String
  title        String
  description  String?
  metadata     Json            @default("{}")
  timestamp    DateTime
  userId       String?         @map("user_id")
  orgId        String          @map("org_id")
  createdAt    DateTime        @default(now()) @map("created_at")
  organization Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user         User?           @relation(fields: [userId], references: [id])

  @@index([orgId, source, timestamp])
  @@index([orgId, type, timestamp])
  @@map("events")
}

model Sprint {
  id           String       @id @default(cuid())
  externalId   String?      @map("external_id")
  name         String
  goal         String?
  status       SprintStatus @default(PLANNING)
  startDate    DateTime     @map("start_date")
  endDate      DateTime     @map("end_date")
  riskScore    Float        @default(0) @map("risk_score")
  metadata     Json         @default("{}")
  teamId       String       @map("team_id")
  orgId        String       @map("org_id")
  createdAt    DateTime     @default(now()) @map("created_at")
  updatedAt    DateTime     @updatedAt @map("updated_at")
  signals      Signal[]
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  team         Team         @relation(fields: [teamId], references: [id], onDelete: Cascade)

  @@map("sprints")
}

model Signal {
  id           String       @id @default(cuid())
  name         String
  category     String
  value        Float
  weight       Float        @default(1.0)
  trend        Trend        @default(STABLE)
  metadata     Json         @default("{}")
  sprintId     String?      @map("sprint_id")
  orgId        String       @map("org_id")
  computedAt   DateTime     @default(now()) @map("computed_at")
  createdAt    DateTime     @default(now()) @map("created_at")
  organization Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  sprint       Sprint?      @relation(fields: [sprintId], references: [id])

  @@map("signals")
}

model Report {
  id           String           @id @default(cuid())
  type         ReportType
  title        String
  summary      String?
  content      Json
  aiNarrative  String?          @map("ai_narrative")
  status       ReportStatus     @default(DRAFT)
  periodStart  DateTime         @map("period_start")
  periodEnd    DateTime         @map("period_end")
  generatedAt  DateTime?        @map("generated_at")
  orgId        String           @map("org_id")
  teamId       String?          @map("team_id")
  createdAt    DateTime         @default(now()) @map("created_at")
  updatedAt    DateTime         @updatedAt @map("updated_at")
  reviewedById String?          @map("reviewed_by_id")
  reviewedAt   DateTime?        @map("reviewed_at")
  reviewNotes  String?          @map("review_notes")
  contexts     ReportContext[]
  deliveries   ReportDelivery[]
  organization Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  reviewedBy   User?            @relation("ReviewedReports", fields: [reviewedById], references: [id])
  team         Team?            @relation(fields: [teamId], references: [id])

  @@map("reports")
}

model ReportDelivery {
  id             String          @id @default(cuid())
  reportId       String          @map("report_id")
  channel        DeliveryChannel @default(IN_APP)
  recipientId    String?         @map("recipient_id")
  recipientEmail String?         @map("recipient_email")
  recipientName  String?         @map("recipient_name")
  recipientRole  String?         @map("recipient_role")
  reportDepth    String?         @map("report_depth")
  status         DeliveryStatus  @default(PENDING)
  sentAt         DateTime?       @map("sent_at")
  openedAt       DateTime?       @map("opened_at")
  viewCount      Int             @default(0) @map("view_count")
  error          String?
  createdAt      DateTime        @default(now()) @map("created_at")
  recipient      User?           @relation(fields: [recipientId], references: [id])
  report         Report          @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@map("report_deliveries")
}

model ReportContext {
  id               String       @id @default(cuid())
  orgId            String       @map("org_id")
  reportId         String       @map("report_id")
  periodStart      DateTime     @map("period_start")
  periodEnd        DateTime     @map("period_end")
  keyMetrics       Json         @map("key_metrics")
  insights         Json         @default("[]")
  actionItems      Json?        @map("action_items")       // ActionItem[] for follow-up tracking
  connectedSources Json?        @map("connected_sources")  // ["GITHUB","SLACK",...]
  signalSummary    Json?        @map("signal_summary")     // { anomalyCount, blockerCount, trendCount }
  createdAt        DateTime     @default(now()) @map("created_at")
  organization     Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  report           Report       @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([orgId, createdAt])
  @@map("report_contexts")
}

model ReportRecipient {
  id             String          @id @default(cuid())
  orgId          String          @map("org_id")
  email          String
  name           String
  role           RecipientRole   @default(TEAM_LEAD)
  reportDepth    ReportDepth     @default(FULL)
  channels       String[]        @default(["EMAIL"])
  slackUserId    String?         @map("slack_user_id")
  active         Boolean         @default(true)
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  organization   Organization    @relation(fields: [orgId], references: [id], onDelete: Cascade)

  @@unique([orgId, email])
  @@index([orgId, active])
  @@map("report_recipients")
}

model DeliveryPreference {
  id         String          @id @default(cuid())
  userId     String          @map("user_id")
  reportType ReportType      @map("report_type")
  channel    DeliveryChannel
  enabled    Boolean         @default(true)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @updatedAt @map("updated_at")
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, reportType, channel])
  @@map("delivery_preferences")
}

enum Role {
  ADMIN
  MEMBER
  VIEWER
}

enum IntegrationType {
  GITHUB
  JIRA
  LINEAR
  SLACK
  GOOGLE_CALENDAR
}

enum IntegrationStatus {
  CONNECTED
  DISCONNECTED
  PENDING
}

enum SprintStatus {
  PLANNING
  ACTIVE
  COMPLETED
  CANCELLED
}

enum Trend {
  UP
  DOWN
  STABLE
}

enum ReportType {
  WEEKLY_DIGEST
  SPRINT_RISK
  MONTHLY_HEALTH
}

enum ReportStatus {
  DRAFT
  GENERATED
  PENDING_REVIEW
  APPROVED
  REJECTED
  DELIVERED
}

enum DeliveryChannel {
  EMAIL
  SLACK
  IN_APP
}

enum DeliveryStatus {
  PENDING
  SENT
  FAILED
}

enum RecipientRole {
  CTO
  VP_ENG
  ENG_DIRECTOR
  TEAM_LEAD
  ENGINEERING_MANAGER
  IC
  STAKEHOLDER
}

enum ReportDepth {
  EXECUTIVE
  STANDARD
  FULL
}
